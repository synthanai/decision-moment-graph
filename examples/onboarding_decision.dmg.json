{
    "dmg_version": "0.1",
    "memo": {
        "memo_id": "dmg-example-001",
        "title": "New Team Onboarding Process",
        "arena_id": "process-design",
        "decision": "Implement a structured 4-week onboarding program with buddy system and milestone checkpoints",
        "context": {
            "constraints": [
                "Budget: $5k per new hire for onboarding",
                "Timeline: Must be ready by Q2",
                "Existing HR systems must be used"
            ],
            "assumptions": [
                "New hires have basic domain knowledge",
                "Buddies will have 2-3 hrs/week bandwidth",
                "Remote-first approach is acceptable"
            ]
        },
        "options": [
            {
                "name": "Option A: Self-Directed",
                "description": "Provide documentation and let new hires self-onboard",
                "pros": [
                    "Low cost",
                    "Flexible timing"
                ],
                "cons": [
                    "Inconsistent outcomes",
                    "Longer ramp-up time"
                ]
            },
            {
                "name": "Option B: Structured Program",
                "description": "4-week program with milestones, buddy, and weekly check-ins",
                "pros": [
                    "Consistent outcomes",
                    "Faster ramp-up",
                    "Better retention"
                ],
                "cons": [
                    "Higher initial investment",
                    "Requires coordination"
                ]
            },
            {
                "name": "Option C: External Bootcamp",
                "description": "Use external training provider for first 2 weeks",
                "pros": [
                    "Professional training",
                    "Standardized content"
                ],
                "cons": [
                    "Expensive",
                    "Generic content",
                    "Less team integration"
                ]
            },
            {
                "name": "Option D: Do Nothing",
                "description": "Continue current ad-hoc approach",
                "pros": [
                    "No change required"
                ],
                "cons": [
                    "High attrition risk",
                    "Inconsistent performance"
                ]
            }
        ],
        "recommendation": "Option B: Structured Program. It balances cost with outcomes and directly addresses retention concerns. The buddy system creates immediate team bonds while milestones ensure consistent progress.",
        "risks": [
            {
                "risk": "Buddy bandwidth may be insufficient",
                "likelihood": "medium",
                "impact": "medium"
            },
            {
                "risk": "Remote onboarding may feel impersonal",
                "likelihood": "medium",
                "impact": "low"
            }
        ],
        "mitigations": [
            "Cap buddy assignments to 1 new hire at a time",
            "Add virtual social events in weeks 1 and 3"
        ],
        "ramp": {
            "level": 3,
            "justification": "Affects team culture and retention; changes require 2+ months to assess",
            "time_to_undo": "2 months"
        },
        "doors": {
            "declare": "We commit to piloting the 4-week structured onboarding for the next 3 hires",
            "observe": [
                "Time to first contribution",
                "30-day satisfaction score",
                "Buddy feedback"
            ],
            "own": {
                "name": "Sarah Chen",
                "role": "People Operations Lead"
            },
            "ready": "Rollback to Option A if satisfaction < 3.5/5 or buddy feedback is negative",
            "signals": [
                {
                    "metric": "30-day satisfaction score",
                    "threshold": "< 3.5/5",
                    "horizon": "After 3 pilots",
                    "action": "Trigger review meeting"
                },
                {
                    "metric": "Time to first contribution",
                    "threshold": "> 6 weeks",
                    "horizon": "Per new hire",
                    "action": "Investigate root cause"
                }
            ]
        },
        "owners": [
