# DMG Open Standard Environment Variables
# Copy to .env and fill in values

# OpenRouter API Key (required for multi-model SPARKIT)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Default dispatcher configuration
DMG_DISPATCHER_TYPE=logging  # logging, http, dry_run
DMG_DISPATCHER_URL=https://api.example.com/decisions

# Optional: Memory persistence
DMG_MEMORY_PATH=./data/decisions.json

# Optional: Logging
DMG_LOG_LEVEL=INFO
DMG_LOG_FILE=./logs/resolve.log
